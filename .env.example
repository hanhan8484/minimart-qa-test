# Copy to `.env` for local notes, then export into your shell before `npm test`.
# Do NOT commit a filled `.env` to a public repository.
#
# Playwright does not auto-load this file — set vars in the shell, e.g.:
#   PowerShell:  $env:BASE_URL = "https://..."
#   bash:        export BASE_URL="https://..."

# Required — assignment MiniMart root URL (no trailing slash)
BASE_URL=https://your-minimart-host.example

# Optional — full Day-0 reset URL (overrides BASE_URL + RESET_PATH)
# RESET_URL=https://your-minimart-host.example/reset-xxxxxxxx

# Optional — reset path segment when RESET_URL is unset (assignment default)
# RESET_PATH=reset-xxxxxxxx

# Optional — override PRD R-1.2 built-in test account
# TEST_USER=demo@minimart.test
# TEST_PASS=
